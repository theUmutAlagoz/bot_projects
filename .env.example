# ============================================
# POLYMARKET BTC BOT — ENVIRONMENT VARIABLES
# ============================================

# Bot Mode: "preview" (paper trading) or "live" (real money)
BOT_MODE=preview

# Polymarket Configuration
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# Your Polymarket Private Key (NEVER share this!)
# If email login: export from https://reveal.magic.link/polymarket
# If Web3 wallet: export from your wallet app
PRIVATE_KEY=your_private_key_here

# Your Polymarket Funder Address (profile address where USDC is)
FUNDER_ADDRESS=your_funder_address_here

# Signature Type: 0 = Browser Wallet (Metamask etc), 1 = Magic/Email Login
SIGNATURE_TYPE=1

# ============================================
# STRATEGY CONFIGURATION
# ============================================

# Trade size in USDC per trade
TRADE_SIZE=2

# Maximum daily loss in USDC (bot stops if hit)
MAX_DAILY_LOSS=10

# Maximum number of trades per day
MAX_DAILY_TRADES=50

# Momentum threshold — minimum price change in $/sec to trigger signal
MOMENTUM_THRESHOLD=15

# Sniper mode — minimum seconds remaining in market to consider sniping
SNIPER_MIN_SECONDS=30

# Sniper mode — minimum price gap ($) from target to consider sniping
SNIPER_MIN_GAP=50

# Minimum confidence level (0-1) to place a trade
MIN_CONFIDENCE=0.60

# Paper trading starting balance (USDC)
STARTING_BALANCE=20

# Advanced strategy tuning
# Time (ms) to wait between new trade signals (prevents overtrading)
SIGNAL_COOLDOWN_MS=15000
# Maximum open positions per market (1 = only one trade per 5m market)
MAX_POSITIONS_PER_MARKET=1

# ============================================
# DASHBOARD
# ============================================
DASHBOARD_PORT=3000
